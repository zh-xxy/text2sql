DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/text2sql

LLM_PROVIDER=openai
LLM_API_KEY=your_api_key
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1

MAX_SQL_RETRIES=3
SQL_TIMEOUT_SECONDS=60
SCHEMA_ALLOW_TABLES=

ANALYZER_SKILLS_DIR=skills
ANALYZER_ENABLE_SKILL_TOOLS=true

RAG_ENABLED=false
RAG_KB_DIR=knowledge_base
RAG_STORE_DIR=outputs/rag_store
RAG_CHUNK_METHOD=semantic
RAG_TOP_K=12
RAG_TOP_N=5
